PHX_SERVER="true"
PHX_HOST="dev.vmemo.app"
SECRET_KEY_BASE="replace_with_a_long_random_secret"

DATABASE_URL="postgres://postgres:postgres@postgres/vmemo"
TYPESENSE_URL="http://typesense:8108"
TYPESENSE_API_KEY="replace_with_typesense_api_key"
# Internal bridge service forwards to host Moondream Station (see docker-compose.yml).
MOONDREAM_URL="http://moondream-station:2020/v1"
MOONDREAM_API_KEY=""
OPENROUTER_API_KEY=""
RESEND_API_KEY=""

ADMIN_TOKEN="replace_with_admin_token"

SENTRY_DSN="https://public@example.com/1"
SENTRY_ENV="vmemo.app"
CLOUDFLARED_TOKEN="replace_with_cloudflared_tunnel_token"

# Optional
# PORT="4000"
# ECTO_IPV6="false"
# POOL_SIZE="10"
# DNS_CLUSTER_QUERY=""
