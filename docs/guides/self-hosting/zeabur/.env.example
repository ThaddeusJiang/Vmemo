PHX_SERVER="true"
PHX_HOST="<your-zeabur-domain>"
SECRET_KEY_BASE="replace_with_a_long_random_secret"

DATABASE_URL="postgres://<user>:<password>@<zeabur-postgres-host>:5432/<db_name>"
TYPESENSE_URL="http://<zeabur-typesense-host>:8108"
TYPESENSE_API_KEY="replace_with_zeabur_typesense_api_key"

MOONDREAM_URL="https://api.moondream.ai/v1/"
MOONDREAM_API_KEY="replace_with_moondream_ai_key"

OPENROUTER_API_KEY=""
RESEND_API_KEY=""
ADMIN_TOKEN="replace_with_admin_token"

SENTRY_DSN=""
SENTRY_ENV="zeabur"

