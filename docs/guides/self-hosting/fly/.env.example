PHX_SERVER="true"
PHX_HOST="<your-fly-domain>"
SECRET_KEY_BASE="replace_with_a_long_random_secret"

DATABASE_URL="postgres://<user>:<password>@<managed-postgres-host>:5432/<db_name>?sslmode=require"
TYPESENSE_URL="https://<managed-typesense-endpoint>"
TYPESENSE_API_KEY="replace_with_managed_typesense_api_key"

MOONDREAM_URL="https://api.moondream.ai/v1/"
MOONDREAM_API_KEY="replace_with_moondream_ai_key"

OPENROUTER_API_KEY=""
RESEND_API_KEY=""
ADMIN_TOKEN="replace_with_admin_token"

SENTRY_DSN=""
SENTRY_ENV="flyio"

# Optional
# PORT="4000"
# ECTO_IPV6="false"
# POOL_SIZE="10"
# DNS_CLUSTER_QUERY=""
